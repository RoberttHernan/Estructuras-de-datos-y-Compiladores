<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="https://github.com/avaloniaui/design"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Compilador2"
        mc:Ignorable="d"
        x:Class="Compilador2.MainWindow"
        Title="MainWindow" Width="800" Height="450">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <StackPanel Margin="20">
        <TextBlock Text="Texto a Analizar:" />
        <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Width="500" Height="700" Margin="0,10,0,0"/>
        
        <Button Content="Analizar" Command="{Binding AnalyzeCommand}" Margin="0,10,0,0"/>
        
        <TextBlock Text="Salida del Visitor:" />
        <TextBox Text="{Binding OutputList, Converter={StaticResource OutputListConverter}, UpdateSourceTrigger=LostFocus}" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Width="400" Height="100" Margin="0,10,0,0"/>

        <TextBlock Text="Lista de Errores:" />
        <TextBox Text="{Binding ErrorList, Converter={StaticResource OutputListConverter}, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Width="400" Height="100" Margin="0,10,0,0"/>
    </StackPanel>
    
</Window>